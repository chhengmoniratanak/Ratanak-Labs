import paramiko
import paramiko
import time

ip_address = "192.168.122.72"
username = "david"
password = "cisco"

# 1. Establish SSH connection
ssh_client = paramiko.SSHClient()
# AutoAddPolicy is used for simplicity, but in a production environment, 
# it's safer to use paramiko.WarningPolicy() or load known hosts.
ssh_client.set_missing_host_key_policy(paramiko.AutoAddPolicy())
try:
    ssh_client.connect(hostname=ip_address, username=username, password=password)
    print(f"Successful connection to {ip_address}") # Python 3 print function and f-string
except paramiko.AuthenticationException:
    print("Authentication failed.")
    exit()
except paramiko.SSHException as e:
    print(f"Could not establish SSH connection: {e}")
    exit()
except Exception as e:
    print(f"An error occurred: {e}")
    exit()

# 2. Invoke interactive shell
remote_connection = ssh_client.invoke_shell()

# 3. Send initial configuration commands
# Note: Strings are now sent as encoded bytes to the socket, 
# but paramiko's .send() often handles the default encoding (like UTF-8) for you.
# If an encoding issue occurs, you might need to use .send(command.encode('ascii'))
print("Sending initial configuration commands...")
remote_connection.send("configure terminal\n")
remote_connection.send("int loop 0\n")
remote_connection.send("ip address 1.1.1.1 255.255.255.255\n")
remote_connection.send("int loop 1\n")
remote_connection.send("ip address 2.2.2.2 255.255.255.255\n")
remote_connection.send("router ospf 1\n")
remote_connection.send("network 0.0.0.0 255.255.255.255 area 0\n")

# 4. Loop to create VLANs
for n in range (2, 21):
    # Python 3 print function and f-string
    print(f"Creating VLAN {n}")
    # Using f-strings to format the command strings
    remote_connection.send(f"vlan {n}\n")
    remote_connection.send(f"name Python_VLAN {n}\n")
    time.sleep(0.5)

# 5. Exit configuration mode
remote_connection.send("end\n")

# 6. Wait and receive output
time.sleep(1)
# Output received from paramiko is often a bytes object in Python 3, 
# so we decode it to a string for printing.
output = remote_connection.recv(65535).decode('utf-8') 
print("\n--- Device Output ---\n")
print(output)
print("\n---------------------\n")

# 7. Close the SSH connection
ssh_client.close()
print("Connection closed.")